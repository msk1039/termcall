# TermCall Server Configuration
# Copy this file to .env and edit the values.
# Only TERMCALL_PUBLIC_IP is required — everything else has sensible defaults.

# ─── REQUIRED ────────────────────────────────────────────

# Your server's public IP address.
# TURN relay needs this to tell clients where to send media.
# Find it with: curl -s ifconfig.me
TERMCALL_PUBLIC_IP=

# ─── PORTS (optional) ───────────────────────────────────

# WebSocket signaling port (clients connect with ws://host:PORT/ws)
# Default: 8080
TERMCALL_WS_PORT=8080

# TURN/STUN listening port (UDP + TCP)
# Recommended: 3478 (standard) or 443 (best for restrictive networks like Jio)
# Default: 3478
TERMCALL_TURN_PORT=3478

# TURN relay UDP port range
# Each relayed connection uses one port from this range.
# Size this based on expected concurrent users (see docs/self-hosting-analysis.md).
# Default: 49152-65535
TERMCALL_RELAY_PORT_MIN=49152
TERMCALL_RELAY_PORT_MAX=65535

# ─── ROOMS (optional) ───────────────────────────────────

# Maximum peers allowed per room
# Default: 5
TERMCALL_MAX_ROOM_SIZE=5

# ─── SECURITY (optional) ────────────────────────────────

# TURN authentication shared secret
# Change this to a random string for production deployments!
# Default: termcall
TERMCALL_TURN_SECRET=termcall
